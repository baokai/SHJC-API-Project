    <div class="lr-layout-body">
        <div class="price-info">
            <div class=" btn-group btn-group-sm">
                <a id="lr_agreList1" class="btn btn-circle"><i class="fa fa-yelp"></i>&nbsp;<span class="lrlg">添加</span></a>
            </div>
            <div class="lr-form-wrap" id="form">

                <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                    <div class="lr-form-item-title">付款类型  <font face="宋体">*</font></div>
                    <div id="PayType" isvalid="yes" checkexpession="NotNull"></div>
                </div>
                <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                    <div class="lr-form-item-title">收款单位名称<font face="宋体">*</font></div>
                    <input id="Payee" type="text" class="form-control" isvalid="yes" checkexpession="NotNull" />
                </div>
                <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                    <div class="lr-form-item-title">收款银行 <font face="宋体">*</font></div>
                    <input id="PayeeBank" type="text" class="form-control" isvalid="yes" checkexpession="NotNull" />
                </div>
                <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                    <div class="lr-form-item-title">银行账号<font face="宋体">*</font></div>
                    <input id="BankAccount" type="text" class="form-control" isvalid="yes" checkexpession="NotNull">
                </div>
                <div class="col-xs-6 lr-form-item" data-table="ProjectPayment">
                    <div class="lr-form-item-title">付款方式 <font face="宋体">*</font></div>
                    <div id="PaymentMethod" isvalid="yes" checkexpession="NotNull"></div>
                </div>
                <div class="col-xs-6 lr-form-item" data-table="ProjectPayment">
                    <div class="lr-form-item-title">我司支付<font face="宋体">*</font></div>
                    <div id="PaymentHeader" isvalid="yes" checkexpession="NotNull"></div>
                </div>
                <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                    <div class="lr-form-item-title">外付事由<font face="宋体">*</font></div>
                    <textarea id="PaymentReason" class="form-control" style="height:100px;" isvalid="yes" checkexpession="NotNull"></textarea>
                </div>
                <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                    <div class="lr-form-item-title">附件上传<font face="宋体">*</font></div>
                    <div id="PaymentFile" isvalid="yes" checkexpession="NotNull"></div>
                </div>
            </div>

            <div class="js-scroll">
                <div class="lr-layout-body" id="gridtable">
                </div>
            </div>
                
