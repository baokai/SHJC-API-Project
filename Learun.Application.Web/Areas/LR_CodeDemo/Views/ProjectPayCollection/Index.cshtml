@{
    ViewBag.Title = "项目回款管理";
    Layout = "~/Views/Shared/_Index.cshtml";
}
<div class="lr-layout" id="lr_layout">
    <div class="lr-layout-center">
        <div class="lr-layout-wrap lr-layout-wrap-notitle ">
            <div class="lr-layout-tool">
                <div class="lr-layout-tool-left">
                    <div class="lr-layout-tool-item">
                        <div id="datesearch"></div>
                    </div>
                    <div class="lr-layout-tool-item">
                        <input id="txt_Keyword" type="text" class="form-control" placeholder="请输入编号/名称" />
                    </div>
                    <div class="lr-layout-tool-item">
                        <a id="btn_Search" class="btn btn-primary btn-sm"><i class="fa fa-search"></i>&nbsp;<span class="lrlg">查询</span></a>
                    </div>
                    <div class="lr-layout-tool-item">
                        <div id="multiple_condition_query">
                            <div class="lr-query-formcontent">
                                <div class="lr-layout-tool-item">

                                    <div class="col-xs-6 lr-form-item" data-table="ProjectPayCollection">
                                        <div class="lr-form-item-title">到账开始</div>
                                        <input id="ReceiptDateStartTime" type="text" class="form-control lr-input-wdatepicker" checkexpession="NotNull" isvalid="yes" onfocus="WdatePicker({ dateFmt:'yyyy-MM-dd',onpicked: function () { $('#ReceiptDate').trigger('change'); } })" />
                                    </div>
                                    <div class="col-xs-6 lr-form-item" data-table="ProjectPayCollection">
                                        <div class="lr-form-item-title">到账结束</div>
                                        <input id="ReceiptDateEndTime" type="text" class="form-control lr-input-wdatepicker" checkexpession="NotNull" isvalid="yes" onfocus="WdatePicker({ dateFmt:'yyyy-MM-dd',onpicked: function () { $('#ReceiptDate').trigger('change'); } })" />
                                    </div>
                                    @*<a id="ReceiptTimekeyword" class="btn btn-primary btn-sm"><i class="fa fa-search"></i>&nbsp;<span class="lrlg">回款时间查询</span></a>*@
                                </div>
                                <div class="col-xs-12 lr-form-item">
                                    <div class="lr-form-item-title">合同编号</div>
                                    <input id="ContractNo" type="text" class="form-control" />
                                </div>
                                <div class="col-xs-12 lr-form-item">
                                    <div class="lr-form-item-title">项目名称</div>
                                    <input id="ProjectName" type="text" class="form-control" />
                                </div>
                                <div class="col-xs-12 lr-form-item">
                                    <div class="lr-form-item-title">委托单位</div>
                                    <input id="CustName" type="text" class="form-control" />
                                </div>
                                <div class="col-xs-12 lr-form-item">
                                    <div class="lr-form-item-title">到款金额</div>
                                    <input id="Amount" type="text" class="form-control" />
                                </div>
                                <div class="col-xs-12 lr-form-item" data-table="ProjectPayCollection">
                                    <div class="lr-form-item-title">到账日期</div>
                                    <input id="ReceiptDate" type="text" class="form-control lr-input-wdatepicker" checkexpession="NotNull" isvalid="yes" " onfocus="WdatePicker({ dateFmt:'yyyy-MM-dd',onpicked: function () { $('#ReceiptDate').trigger('change'); } })" />
                                </div>
                                <div class="col-xs-12 lr-form-item">
                                    <div class="lr-form-item-title">到款单位</div>
                                    <input id="PaymentUnit" type="text" class="form-control" checkexpession="NotNull" isvalid="yes" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="lr-layout-tool-item">
                        <span style="margin-right:10px;margin-left:10px">到款金额：</span>
                        <input id="AmountSUM" type="text" class="form-control" readonly style="width:260px" />
                    </div>
                    @*<div class="lr-layout-tool-item">
                        <span style="margin-right:10px;margin-left:10px">到款绩效：</span>
                        <input id="JXAmountSUM" type="text" class="form-control" readonly style="width:260px" />
                    </div>*@
                </div>
                <div class="lr-layout-tool-right">
                    <div class=" btn-group btn-group-sm">
                        <a id="lr_refresh" class="btn btn-default"><i class="fa fa-refresh"></i></a>
                    </div>
                    <div class=" btn-group btn-group-sm" learun-authorize="yes">
                        
                        <a id="lr_preview" class="btn btn-default">预览</a>
                        <a id="lr_add" class="btn btn-default"><i class="fa fa-plus"></i>&nbsp;新增</a>
                        <a id="lr_edit" class="btn btn-default"><i class="fa fa-pencil-square-o"></i>&nbsp;编辑</a>
                        <a id="lr_delete" class="btn btn-default"><i class="fa fa-trash-o"></i>&nbsp;删除</a>
                        <a id="lr_print" class="btn btn-default"><i class="fa fa-print"></i>&nbsp;打印</a>
                        <a id="lr-export" class="btn btn-default"><i class="fa fa-sign-out"></i>&nbsp;<span class="lrlg">导出</span></a>
                    </div>
                </div>
            </div>
            <div class="lr-layout-body" id="gridtable"></div>
        </div>
    </div>
</div>

@Html.AppendJsFile("/Areas/LR_CodeDemo/Views/ProjectPayCollection/Index.js")
