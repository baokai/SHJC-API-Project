@{
    ViewBag.Title = "项目合同申请";
    Layout = "~/Views/Shared/_Index.cshtml";
}
<div class="lr-layout "  >
    <div class="lr-layout-center">
        <div class="lr-layout-wrap lr-layout-wrap-notitle ">
            <div class="lr-layout-tool">
                <div class="lr-layout-tool-left">
                    <div class="lr-layout-tool-item">
                        <div id="datesearch"></div>
                    </div>
                    <div class="lr-layout-tool-item">
                        <input id="txt_Keyword" type="text" class="form-control" placeholder="请输入编号/名称" />
                    </div>
                    <div class="lr-layout-tool-item">
                        <a id="btn_Search" class="btn btn-primary btn-sm"><i class="fa fa-search"></i>&nbsp;<span class="lrlg">查询</span></a>
                    </div>
                    <div class="lr-layout-tool-item">
                        <div id="multiple_condition_query">
                            <div class="lr-query-formcontent">
                                <div class="col-xs-12 lr-form-item">
                                    <div class="lr-form-item-title">合同编号</div>
                                    <input id="ContractNo" type="text" class="form-control" />
                                </div>
                                <div class="col-xs-12 lr-form-item">
                                    <div class="lr-form-item-title">项目名称</div>
                                    <input id="ProjectName" type="text" class="form-control"/>
                                </div>
                                <div class="col-xs-12 lr-form-item">
                                    <div class="lr-form-item-title">委托单位</div>
                                    <input id="CustName" type="text" class="form-control"/>
                                </div>
                                <div class="col-xs-12 lr-form-item">
                                    <div class="lr-form-item-title">联系人</div>
                                    <input id="ContactPhone" type="text" class="form-control"/>
                                </div>
                                <div class="col-xs-12 lr-form-item" data-table="ProjectContract">
                                    <div class="lr-form-item-title">合同主体</div>
                                    <div id="ContractSubject" checkexpession="NotNull" isvalid="yes"></div>
                                </div>
                                <div class="col-xs-12 lr-form-item" data-table="ProjectContract">
                                    <div class="lr-form-item-title">营销部门</div>
                                    <div id="DepartmentId" checkexpession="NotNull" isvalid="yes"></div>
                                </div>
                                <div class="col-xs-12 lr-form-item" data-table="Project">
                                    <div class="lr-form-item-title">营销人员</div>
                                    <div id="FollowPerson"></div>
                                </div>
                                <div class="col-xs-12 lr-form-item" data-table="Project">
                                    <div class="lr-form-item-title">项目来源</div>
                                    <div id="ProjectSource" readonly></div>
                                </div>
                                <div class="col-xs-12 lr-form-item" data-table="ProjectContract">
                                    <div class="lr-form-item-title">合同状态</div>
                                    <div id="ContractStatus"></div>
                                </div>
                                <div class="col-xs-12 lr-form-item">
                                    <div class="lr-form-item-title">合同金额</div>
                                    <input id="ContractAmount" type="text" class="form-control"/>
                                </div>
                                <div class="col-xs-12 lr-form-item" data-table="ProjectContract">
                                    <div class="lr-form-item-title">合同分类</div>
                                    <div id="ContractType" checkexpession="NotNull" isvalid="yes"></div>
                                </div>
                                <div class="col-xs-12 lr-form-item">
                                    <div class="lr-form-item-title">是否归档</div>
                                    <div id="ReceivedFlag"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="lr-layout-tool-right">
                    <div class=" btn-group btn-group-sm">
                        <a id="lr_refresh" class="btn btn-default"><i class="fa fa-refresh"></i></a>
                    </div>
                    <div class=" btn-group btn-group-sm" learun-authorize="yes">
                        @*<a id="lr_fill" class="btn btn-default">增补</a>*@
                        <a id="AmountList" class="btn btn-default">有效合同额刷新</a>
                        <a id="edit" class="btn btn-default">审核修改</a>
                        @*<a id="lr_import" class="btn btn-default">导入</a>*@
                        @*<a id="lr_change" class="btn btn-default">变更</a>*@
                        <a id="lr_preview" class="btn btn-default">预览</a>
                        <a id="lr_cancel" class="btn btn-default">取消</a>
                        <a id="lr_update" class="btn btn-default">修改</a>
                        <a id="lr-export" class="btn btn-default"><i class="fa fa-sign-out"></i>&nbsp;<span class="lrlg">导出</span></a>
                        <a id="lr_add" class="btn btn-default"><i class="fa fa-plus"></i>&nbsp;新增</a>
                        <a id="lr_edit" class="btn btn-default"><i class="fa fa-pencil-square-o"></i>&nbsp;编辑</a>
                        <a id="lr_delete" class="btn btn-default"><i class="fa fa-trash-o"></i>&nbsp;删除</a>
                        @*<a id="lr_print" class="btn btn-default"><i class="fa fa-print"></i>&nbsp;打印</a>*@

                    </div>
                    <div class=" btn-group btn-group-sm" learun-authorize="yes">
                        <a id="lr_approve" class="btn btn-default"><i class="fa fa-user-circle"></i>&nbsp;提审</a>
                        <a id="lr_receipt" class="btn btn-default"><i class="fa fa-print"></i>&nbsp;合同归档</a>
                    </div>
                </div>
            </div>
            <div class="lr-layout-body" id="gridtable"></div>
        </div>
    </div>
</div>
@Html.AppendJsFile("/Areas/LR_CodeDemo/Views/ProjectContract/IndexDepartmentId.js")
