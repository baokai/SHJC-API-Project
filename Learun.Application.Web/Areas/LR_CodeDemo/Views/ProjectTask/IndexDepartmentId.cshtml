@{
    ViewBag.Title = "项目任务单";
    Layout = "~/Views/Shared/_Index.cshtml";
}
<div class="lr-layout "  >
    <div class="lr-layout-center">
        <div class="lr-layout-wrap lr-layout-wrap-notitle ">
            <div class="lr-layout-tool">
                <div class="lr-layout-tool-left">
                    <div class="lr-layout-tool-item">
                        <div id="datesearch"></div>
                    </div>
                    <div class="lr-layout-tool-item">
                        <input id="txt_Keyword" type="text" class="form-control" placeholder="请输入编号/名称" />
                    </div>
                    <div class="lr-layout-tool-item">
                        <a id="btn_Search" class="btn btn-primary btn-sm"><i class="fa fa-search"></i>&nbsp;<span class="lrlg">查询</span></a>
                    </div>
                    <div class="lr-layout-tool-item">
                        @*<img src="@Url.Action("ShowQRCode")" />*@
                    </div>
                    <div class="lr-layout-tool-item">
                        <div id="multiple_condition_query">
                            <div class="lr-query-formcontent">
                                <div class="col-xs-12 lr-form-item">
                                    <div class="lr-form-item-title">合同编号</div>
                                    <input id="ContractNo" type="text" class="form-control" />
                                </div>
                                <div class="col-xs-12 lr-form-item">
                                    <div class="lr-form-item-title">项目名称</div>
                                    <input id="ProjectName" type="text" class="form-control"></input>
                                </div>
                                <div class="col-xs-12 lr-form-item">
                                    <div class="lr-form-item-title">委托单位</div>
                                    <input id="CustName" type="text" class="form-control"></input>
                                </div>
                                <div class="col-xs-12 lr-form-item">
                                    <div class="lr-form-item-title">联系人</div>
                                    <input id="ContactPhone" type="text" class="form-control"></input>
                                </div>
                                <div class="col-xs-12 lr-form-item" data-table="ProjectTask">
                                    <div class="lr-form-item-title">项目负责人<font face="宋体">*</font></div>
                                    <div id="ProjectResponsible" checkexpession="NotNull" isvalid="yes"></div>
                                </div>
                                <div class="col-xs-12 lr-form-item" data-table="ProjectTask">
                                    <div class="lr-form-item-title">进场时间<font face="宋体">*</font></div>
                                    <input id="ApproachTime" type="text" class="form-control lr-input-wdatepicker" checkexpession="NotNull" isvalid="yes" onfocus="WdatePicker({ dateFmt:'yyyy-MM-dd',onpicked: function () { $('#ApproachTime').trigger('change'); } })" />
                                </div>
                                <div class="col-xs-12 lr-form-item" data-table="ProjectTask">
                                    <div class="lr-form-item-title">报告计划时间<font face="宋体">*</font></div>
                                    <input id="PlanTime" type="text" class="form-control lr-input-wdatepicker" checkexpession="NotNull" isvalid="yes" onfocus="WdatePicker({ dateFmt:'yyyy-MM-dd',onpicked: function () { $('#PlanTime').trigger('change'); } })" />
                                </div>
                                <div class="col-xs-12 lr-form-item">
                                    <div class="lr-form-item-title">任务状态</div>
                                    <div id="TaskStatus"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="lr-layout-tool-right">
                    <div class=" btn-group btn-group-sm">
                        <a id="lr_refresh" class="btn btn-default"><i class="fa fa-refresh"></i></a>
                    </div>
                    <div class=" btn-group btn-group-sm" learun-authorize="yes">
                        <a id="lr_timeout" class="btn btn-default">超时查询</a>
                        <a id="lr_editTask" class="btn btn-default">子报告</a>
                        <a id="lr_Contractpreview" class="btn btn-default">合同查看</a>
                        <a id="lr_fielded" class="btn btn-default">签到</a>
                        <a id="lr_leave" class="btn btn-default">离场</a>
                        <a id="QRCode" class="btn btn-default">生成二维码</a>
                        @*<a id="lr_change" class="btn btn-default">变更</a>*@
                        <a id="lr_preview" class="btn btn-default">预览</a>
                        <a id="lr_add" class="btn btn-default"><i class="fa fa-plus"></i>&nbsp;新增</a>
                        <a id="lr_edit" class="btn btn-default"><i class="fa fa-pencil-square-o"></i>&nbsp;编辑</a>
                        <a id="lr_editName" class="btn btn-default"><i class="fa fa-pencil-square-o"></i>&nbsp;编辑人员</a>
                        <a id="lr_delete" class="btn btn-default"><i class="fa fa-trash-o"></i>&nbsp;删除</a>
                        @*<a id="lr_print" class="btn btn-default"><i class="fa fa-print"></i>&nbsp;打印</a>*@
                    </div>
                    <div class=" btn-group btn-group-sm" learun-authorize="yes">
                        <a id="lr-export" class="btn btn-default"><i class="fa fa-sign-out"></i>&nbsp;<span class="lrlg">导出</span></a>
                        <a id="lr_approve" class="btn btn-default"><i class="fa fa-user-circle"></i>&nbsp;提审</a>
                        <a id="lr_report" class="btn btn-default"><i class="fa fa-cloud-upload"></i>&nbsp;上传报告</a>
                    </div>
                </div>
            </div>
            <div class="lr-layout-body" id="gridtable"></div>
        </div>
    </div>
</div>
@Html.AppendJsFile("/Areas/LR_CodeDemo/Views/ProjectTask/IndexDepartmentId.js")
