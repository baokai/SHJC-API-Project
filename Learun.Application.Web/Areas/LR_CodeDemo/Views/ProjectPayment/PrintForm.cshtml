@{
    ViewBag.Title = "合同支付";
    Layout = "~/Views/Shared/_Form.cshtml";
}
<link href="~/Content/signet/jquery.zsign.css" rel="stylesheet" />
<script src="~/Content/signet/jquery.zsign.js"></script>
<div class="lr-form-wrap" id="form">
    <div class="price-info">
        <div class="form" width="800" id="gridtable">

            <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">

                <input id="ProjectName" checkexpession="NotNull" class="form-control" isvalid="yes" data-table="ProjectPayment" style="text-align: center; font-weight: bolder; border-left: 0px; border-top: 0px; border-right: 0px; border-bottom: 0px; text-align: center; font-size: 20px" readonly />
            </div>
            <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                <div class="lr-form-item-title">项目名称<font face="宋体">*</font></div>
                <input id="ProjectName" checkexpession="NotNull" class="form-control" isvalid="yes" data-table="ProjectPayment" readonly />
            </div>
            <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                <div class="lr-form-item-title">创建人</div>
                <input id="CreateUserName" type="text" class="form-control" readonly />
            </div>
            <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                <div class="lr-form-item-title">创建时间</div>
                <input id="CreateTime" type="text" class="form-control lr-input-wdatepicker" readonly />
            </div>
            <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                <div class="lr-form-item-title">付款类型  <font face="宋体">*</font></div>
                <input id="PayTypeName" isvalid="yes" class="form-control" checkexpession="NotNull" readonly/>
            </div>
            <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                <div class="lr-form-item-title">收款单位名称<font face="宋体">*</font></div>
                <input id="Payee" type="text" class="form-control" isvalid="yes" checkexpession="NotNull" readonly />
            </div>
            <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                <div class="lr-form-item-title">收款银行<font face="宋体">*</font></div>
                <input id="PayeeBank" type="text" class="form-control" isvalid="yes" checkexpession="NotNull" readonly />
            </div>
            <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                <div class="lr-form-item-title">银行账号<font face="宋体">*</font></div>
                <input id="BankAccount" type="text" class="form-control" isvalid="yes" checkexpession="NotNull" readonly>
            </div>
            <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                <div class="lr-form-item-title">支付金额<font face="宋体">*</font></div>
                <input id="PaymentAmount" type="text" class="form-control" isvalid="yes" checkexpession="NotNull" readonly />
            </div>
            <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                <div class="lr-form-item-title">付款方式 <font face="宋体">*</font></div>
                <input id="PaymentMethodName" isvalid="yes"  class="form-control" checkexpession="NotNull" readonly/>
            </div>
            <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                <div class="lr-form-item-title">我司支付<font face="宋体">*</font></div>
                <input id="PaymentHeaderName" isvalid="yes"  class="form-control" checkexpession="NotNull" readonly>
            </div>
            <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                <div class="lr-form-item-title">外付事由<font face="宋体">*</font></div>
                <textarea id="PaymentReason" class="form-control" style="height:100px;" isvalid="yes" checkexpession="NotNull" readonly></textarea>
            </div>

            <div class="col-xs-12 lr-form-item" data-table="ProjectPayment">
                <div class="lr-form-item-title">附件上传<font face="宋体">*</font></div>
                <div id="PaymentFile" isvalid="yes" checkexpession="NotNull"></div>
            </div>
        </div>
</div>
 </div>
    @Html.AppendJsFile("/Areas/LR_CodeDemo/Views/ProjectPayment/PrintForm.js")
