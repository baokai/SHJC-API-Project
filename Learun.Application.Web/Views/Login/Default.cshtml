<!DOCTYPE html>
<html lang="zh-cn">
<head>
    <meta name=”renderer” content=”webkit|ie-comp|ie-stand” />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="content-type" content="text/html; charset=UTF-8">
    <meta http-equiv="X-UA-Compatible" content="chrome=1,IE=edge">
     <link rel="icon" href="~/favicon.ico">
     <title>上海钧测项目管理系统 - 登录页面</title>
    @*<script src="http://res.wx.qq.com/connect/zh_CN/htmledition/js/wxLogin.js"></script>*@
</head>

<body>
    @Html.AppendCssFile("/Views/Login/Default/Index.css")
    @*<div>
            <img src="~/Content/images/Login/login_top.jpg" width="100%" />
        </div>*@
    @*<div class="login_top">
        <img src="~/Content/images/Login/login_top1.jpg" />
    </div>*@
    <img src="~/Content/images/Login/login_top_bj_new2.jpg" />

    @*<input id="errornum" type="hidden" value="@ViewBag.errornum" />*@
    <div class="lr-login-body">
        @*<div class="lr-login-logo">
            <img src="~/Content/images/Login/logow.png" alt="" style="max-width:200px;max-height:200px;">
            <div class="lr-login-title">
                项目管理系统
            </div>
        </div>*@
        <div class="lr-login-middle">
            <img src="~/Content/images/Login/default_left.jpg" />
            <!--登录框 正常登录-->
            <div class="lr-login-main lr-login-normal">
                <div style="width:100%;display:flex;flex-direction:row;align-items:flex-end;justify-content:center;position:absolute;top:20px;right:0;">
                    <img src="~/Content/images/Login/logow.png" alt="" style="max-width:100px;max-height:100px;">
                    <p style="margin-left:10px;font-size:18px;">
                        项目管理系统
                    </p>
                </div>
                <!--密码登录-->
                <div class="lr-login-bypsw noreg">
                    <div class="error_info">*&nbsp;<span>密码不正确</span></div>
                    <img class="lr-login-toCode" login-access="psw" src="~/Content/images/Login/default_code.png" alt="">
                    <div class="lr-login-input">
                        <img class="inp_icon" src="~/Content/images/Login/default_account0.png" alt=""> <input id="lr_username" type="text" placeholder="手机号/帐号">
                    </div>
                    <div class="lr-login-input">
                        <img class="inp_icon" src="~/Content/images/Login/default_psw0.png" alt=""><input id="lr_password" type="password" placeholder="密码">
                        <span id="psw_change"></span>
                    </div>
                    <div class="lr-login-input lr-login-reg">
                        <img class="inp_icon" src="~/Content/images/Login/default_reg0.png" alt=""><input id="lr_verifycode_input" type="text" placeholder="验证码">
                        <img class="code" id="lr_verifycode_img" src="~/Login/VerifyCode" alt="点击切换验证码" title="点击切换验证码" />
                    </div>
                    <div class="lr-login-btn" id="lr_login_btn"><span>登录</span></div>
                    @*<div class="lr-login-weixin" style="font-size: 12px;margin-top: 15px;text-align: right;padding-right: 71px;"><a href="https://open.weixin.qq.com/connect/qrconnect?appid=wxd75b6651c86f816b&redirect_uri=http%3a%2f%2fwww.learun.cn&response_type=code&scope=snsapi_login&state=STATE#wechat_redirect">微信登录</a></div>*@
                    <div class="lr-login-version">版本号：@Html.GetVer()</div>
                </div>

                <!--二维码登录-->
                <div class="lr-login-bycode">

                    <img class="lr-login-toCode" src="~/Content/images/Login/windos_pc.png" alt="">
                    <div class="lr-login-info" id="wechatimg">
                        <img src="~/Content/images/Login/qrcode.png" alt="">
                        <p>微信扫一扫 获体验资格</p>
                    </div>
                </div>

            </div>
        </div>
    </div>
    <div class="lr-login-footer" style="margin-left:-80px;"> <p>信义钧测 一字千钧</p></div>

    <script src="~/Content/jquery/jquery-1.10.2.min.js"></script>
    <script src="~/Content/jquery/jquery.md5.min.js"></script>
    <script>
        function request(d) { for (var c = location.search.slice(1).split("&"), a = 0; a < c.length; a++) { var b = c[a].split("="); if (b[0] == d) if ("undefined" == unescape(b[1])) break; else return unescape(b[1]) } return "" };
        $.rootUrl = '@Url.Content("~")'.substr(0, '@Url.Content("~")'.length - 1);
        $.lrToken = $('@Html.AntiForgeryToken()').val();
        //var obj = new WxLogin({
        //    self_redirect: false,
        //    id: "wechatimg",
        //    appid: "wxd75b6651c86f816b",
        //    scope: "snsapi_login",
        //    redirect_uri: "http%3a%2f%2fwww.learun.cn",
        //    state: "",
        //    style: "",
        //    href: ""
        //});
    </script>
    @Html.AppendJsFile("/Views/Login/Default/Index.js")
</body>
</html>